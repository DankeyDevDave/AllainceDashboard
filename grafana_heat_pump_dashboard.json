{
  "dashboard": {
    "title": "Heat Pump Energy & Performance Monitor",
    "tags": ["heat-pump", "energy", "aquatemp"],
    "timezone": "Africa/Johannesburg",
    "editable": true,
    "refresh": "30s",
    "time": {
      "from": "now-24h",
      "to": "now"
    },
    "templating": {
      "list": [
        {
          "name": "device",
          "label": "Heat Pump Device",
          "type": "custom",
          "options": [
            {
              "text": "All Devices",
              "value": ".*",
              "selected": true
            },
            {
              "text": "Aloha Sensory Aquatics",
              "value": "aloha_sensory_aquatics"
            },
            {
              "text": "House Levy Heatpump",
              "value": "house_levy_heatpump"
            },
            {
              "text": "Heat Pump",
              "value": "heat_pump"
            }
          ],
          "current": {
            "text": "All Devices",
            "value": ".*"
          }
        },
        {
          "name": "interval",
          "label": "Aggregation Interval",
          "type": "interval",
          "auto": true,
          "auto_count": 30,
          "auto_min": "10s",
          "options": [
            { "text": "Auto", "value": "$__auto_interval_interval", "selected": true },
            { "text": "1m", "value": "1m" },
            { "text": "5m", "value": "5m" },
            { "text": "15m", "value": "15m" },
            { "text": "1h", "value": "1h" }
          ]
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "Current Power Consumption",
        "type": "stat",
        "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "refId": "A",
            "query": "from(bucket: \"homeassistant\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r[\"entity_id\"] =~ /${device}/ and r[\"entity_id\"] =~ /actual_power_z04/)\n  |> filter(fn: (r) => r[\"_field\"] == \"value\")\n  |> last()\n  |> map(fn: (r) => ({ r with _value: float(v: r._value) }))"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "watt",
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 1000, "color": "yellow" },
                { "value": 2500, "color": "red" }
              ]
            },
            "mappings": []
          }
        },
        "options": {
          "graphMode": "area",
          "colorMode": "value",
          "justifyMode": "auto",
          "textMode": "value_and_name",
          "orientation": "auto"
        }
      },
      {
        "id": 2,
        "title": "Today's Energy Consumption",
        "type": "stat",
        "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "refId": "A",
            "query": "from(bucket: \"homeassistant\")\n  |> range(start: -1d)\n  |> filter(fn: (r) => r[\"entity_id\"] =~ /${device}/ and r[\"entity_id\"] =~ /cumulative_power_consumption_z06/)\n  |> filter(fn: (r) => r[\"_field\"] == \"value\")\n  |> aggregateWindow(every: 1d, fn: spread)\n  |> map(fn: (r) => ({ r with _value: float(v: r._value) }))"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "kwatth",
            "color": { "mode": "palette-classic" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "green" }
              ]
            }
          }
        },
        "options": {
          "graphMode": "area",
          "colorMode": "value"
        }
      },
      {
        "id": 3,
        "title": "Compressor Runtime Today",
        "type": "stat",
        "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "refId": "A",
            "query": "from(bucket: \"homeassistant\")\n  |> range(start: -1d)\n  |> filter(fn: (r) => r[\"entity_id\"] =~ /${device}/ and r[\"entity_id\"] =~ /compressor_operational_time_z08/)\n  |> filter(fn: (r) => r[\"_field\"] == \"value\")\n  |> aggregateWindow(every: 1d, fn: spread)\n  |> map(fn: (r) => ({ r with _value: float(v: r._value) }))"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "h",
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 12, "color": "yellow" },
                { "value": 20, "color": "red" }
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "System Status",
        "type": "stat",
        "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
        "targets": [
          {
            "refId": "A",
            "query": "from(bucket: \"homeassistant\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r[\"entity_id\"] =~ /${device}/ and r[\"entity_id\"] =~ /power/)\n  |> filter(fn: (r) => r[\"_field\"] == \"value\")\n  |> last()"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              { "type": "value", "value": "on", "text": "Running", "color": "green" },
              { "type": "value", "value": "off", "text": "Off", "color": "red" }
            ],
            "color": { "mode": "thresholds" }
          }
        }
      },
      {
        "id": 5,
        "title": "Power Consumption - Last 24 Hours",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
        "targets": [
          {
            "refId": "A",
            "query": "from(bucket: \"homeassistant\")\n  |> range(start: -24h)\n  |> filter(fn: (r) => r[\"entity_id\"] =~ /${device}/ and r[\"entity_id\"] =~ /actual_power_z04/)\n  |> filter(fn: (r) => r[\"_field\"] == \"value\")\n  |> aggregateWindow(every: ${interval}, fn: mean, createEmpty: false)\n  |> map(fn: (r) => ({ r with _value: float(v: r._value) }))"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "watt",
            "color": { "mode": "palette-classic" },
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 20,
              "gradientMode": "opacity",
              "axisPlacement": "auto",
              "drawStyle": "line"
            }
          },
          "overrides": []
        },
        "options": {
          "tooltip": { "mode": "multi" },
          "legend": { "displayMode": "list", "placement": "bottom" }
        }
      },
      {
        "id": 6,
        "title": "Temperature Monitoring",
        "type": "timeseries",
        "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
        "targets": [
          {
            "refId": "A",
            "query": "from(bucket: \"homeassistant\")\n  |> range(start: -6h)\n  |> filter(fn: (r) => r[\"entity_id\"] =~ /${device}/ and (r[\"entity_id\"] =~ /inlet_water_temp/ or r[\"entity_id\"] =~ /outlet_water_temp/ or r[\"entity_id\"] =~ /ambient_temp/))\n  |> filter(fn: (r) => r[\"_field\"] == \"value\")\n  |> aggregateWindow(every: ${interval}, fn: mean, createEmpty: false)"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "celsius",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 7,
        "title": "Daily Energy Consumption - Last 7 Days",
        "type": "barchart",
        "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
        "targets": [
          {
            "refId": "A",
            "query": "from(bucket: \"homeassistant\")\n  |> range(start: -7d)\n  |> filter(fn: (r) => r[\"entity_id\"] =~ /${device}/ and r[\"entity_id\"] =~ /cumulative_power_consumption_z06/)\n  |> filter(fn: (r) => r[\"_field\"] == \"value\")\n  |> aggregateWindow(every: 1d, fn: spread, createEmpty: false)\n  |> map(fn: (r) => ({ r with _value: float(v: r._value) }))"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "kwatth",
            "color": { "mode": "palette-classic" }
          }
        }
      },
      {
        "id": 8,
        "title": "Water Temperature Delta (Heating Effectiveness)",
        "type": "timeseries",
        "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
        "targets": [
          {
            "refId": "A",
            "query": "inlet = from(bucket: \"homeassistant\")\n  |> range(start: -6h)\n  |> filter(fn: (r) => r[\"entity_id\"] =~ /${device}/ and r[\"entity_id\"] =~ /inlet_water_temp/)\n  |> filter(fn: (r) => r[\"_field\"] == \"value\")\n\noutlet = from(bucket: \"homeassistant\")\n  |> range(start: -6h)\n  |> filter(fn: (r) => r[\"entity_id\"] =~ /${device}/ and r[\"entity_id\"] =~ /outlet_water_temp/)\n  |> filter(fn: (r) => r[\"_field\"] == \"value\")\n\njoin(\n  left: inlet,\n  right: outlet,\n  on: [\"_time\"],\n  as: (l, r) => ({\n    _time: l._time,\n    _value: r._value - l._value,\n    entity_id: \"temperature_delta\"\n  })\n)"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "celsius",
            "color": { "mode": "palette-classic" },
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 30,
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  { "value": 0, "color": "red" },
                  { "value": 2, "color": "yellow" },
                  { "value": 4, "color": "green" }
                ]
              }
            }
          }
        }
      },
      {
        "id": 9,
        "title": "Hourly Energy Consumption",
        "type": "gauge",
        "gridPos": { "x": 0, "y": 20, "w": 6, "h": 6 },
        "targets": [
          {
            "refId": "A",
            "query": "from(bucket: \"homeassistant\")\n  |> range(start: -1h)\n  |> filter(fn: (r) => r[\"entity_id\"] =~ /${device}/ and r[\"entity_id\"] =~ /electricity_consumption_per_hour_z07/)\n  |> filter(fn: (r) => r[\"_field\"] == \"value\")\n  |> last()"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "kwatth",
            "max": 5,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 2, "color": "yellow" },
                { "value": 4, "color": "red" }
              ]
            }
          }
        }
      },
      {
        "id": 10,
        "title": "Total Compressor Runtime",
        "type": "stat",
        "gridPos": { "x": 6, "y": 20, "w": 6, "h": 6 },
        "targets": [
          {
            "refId": "A",
            "query": "from(bucket: \"homeassistant\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r[\"entity_id\"] =~ /${device}/ and r[\"entity_id\"] =~ /compressor_operational_time_z08/)\n  |> filter(fn: (r) => r[\"_field\"] == \"value\")\n  |> last()\n  |> map(fn: (r) => ({ r with _value: float(v: r._value) }))"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "h",
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 2000, "color": "yellow" },
                { "value": 4000, "color": "orange" }
              ]
            }
          }
        },
        "options": {
          "graphMode": "none",
          "text": { "titleSize": 16, "valueSize": 32 }
        }
      },
      {
        "id": 11,
        "title": "Cumulative Energy by Tariff",
        "type": "piechart",
        "gridPos": { "x": 12, "y": 20, "w": 6, "h": 6 },
        "targets": [
          {
            "refId": "A",
            "query": "from(bucket: \"homeassistant\")\n  |> range(start: -5m)\n  |> filter(fn: (r) => r[\"entity_id\"] =~ /${device}/ and (r[\"entity_id\"] =~ /cumulative_power_consumption_z06/ or r[\"entity_id\"] =~ /cumulative_power_consumption_low_z06_l/))\n  |> filter(fn: (r) => r[\"_field\"] == \"value\")\n  |> last()"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "kwatth"
          }
        },
        "options": {
          "pieType": "pie",
          "displayLabels": ["percent"]
        }
      },
      {
        "id": 12,
        "title": "Mode Timeline",
        "type": "state-timeline",
        "gridPos": { "x": 18, "y": 20, "w": 6, "h": 6 },
        "targets": [
          {
            "refId": "A",
            "query": "from(bucket: \"homeassistant\")\n  |> range(start: -24h)\n  |> filter(fn: (r) => r[\"entity_id\"] =~ /${device}/ and r[\"entity_id\"] =~ /mode/)\n  |> filter(fn: (r) => r[\"_field\"] == \"value\")"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              { "type": "value", "value": "heat", "color": "red" },
              { "type": "value", "value": "cool", "color": "blue" },
              { "type": "value", "value": "auto", "color": "green" },
              { "type": "value", "value": "off", "color": "dark-gray" }
            ]
          }
        }
      }
    ]
  },
  "overwrite": true
}
